# approach.toml — the single config file (spec §6, §8): model routing,
# channel bindings, identities, session TTLs, policy matrix.
#
# This file is security-load-bearing, so the loader fails loud: unknown
# keys are errors, enums are closed, missing policy cells mean deny.
# Never put credentials here — every secret lives with the verb that
# uses it (daemon/systemd credentials or an MCP server), per §7.

# Model routing, keyed on event kind (§8). message and heartbeat are
# required: the interactive model is pinned here deliberately — the
# CLI's own default is settings-derived, don't rely on it.
[models]
heartbeat = "claude-haiku-4-5"
message   = "claude-sonnet-5"
heavy     = "claude-opus-4-8"   # optional: heavy work
critique  = "codex"             # optional: C12 on-demand critique

# Channel bindings with auth grading (§6). strong = platform- or
# network-authenticated (discord, slack, tailscale UI); weak = spoofable
# (sms e164, email From). A weak channel is clamped to at most 'known'
# trust, is read-only (no mutating verbs), and can never satisfy an
# approval.
[channels.discord]
auth = "strong"
# Path to the bot token — the file's CONTENT is the secret, this is just
# where to read it. Works as a systemd credential:
#   LoadCredential=discord:/path/to/token  →  token_file = "/run/credentials/approach.service/discord"
token_file = "/run/credentials/approach.service/discord"

[channels.sms]
auth = "weak"

# Hand-enrolled identities seeding the identities table (§6).
# (channel, native_id) -> trust; anyone unlisted is untrusted,
# deny-by-default. owner rows need owner_id — the canonical principal
# shared across all the owner's surfaces (cross-surface approval, §4.4).
# Owner trust on a weak-auth channel is rejected at load time.
[[identity]]
channel   = "discord"
native_id = "000000000000000000"
trust     = "owner"
owner_id  = "brian"
label     = "Brian (Discord)"

[[identity]]
channel   = "sms"
native_id = "+15555550100"
trust     = "known"
label     = "Brian (SMS — weak channel, read-only)"

# Session rotation inputs (C4, §4.1). Defaults shown.
[sessions]
idle_ttl = "4h"
turn_cap = 50

# Policy matrix overrides (§7) — capability x {owner, known, untrusted}
# with actions allow | ask | gate | deny | sandbox. Omit this section to
# get the spec's default table. An override replaces its capability's
# whole row; a column left out is DENY, not the default cell.
# Capabilities: read, schedule, web_fetch, bash, edit, host_exec,
# git_push, send_same_thread, send_other_surface, memory_write, codex,
# task_graph_write.
#
# Example: tighten web fetch for known-group sessions.
[policy.matrix.web_fetch]
owner     = "allow"
known     = "ask"
untrusted = "sandbox"

# The Claude Code engine pin (§2, §7, §11). The daemon verifies the
# binary's --version against this pin at startup and refuses to boot
# on drift — the hook lifecycle is version-sensitive, so a silent CLI
# upgrade would change the enforcement substrate. hooks declares the
# enrolled hook set as config, one reviewable place. Omit the whole
# section for an engine-less (dormant) daemon.
[engine]
bin = "/usr/local/bin/claude"
version = "2.1.199"
max_turns = 25        # --max-turns per spawn (§11); default 25
turn_timeout = "10m"  # wall-clock kill per turn (§11); default 10m
# The §7 cost alarm: `approach status` (and later the heartbeat
# checklist) reports OVER once today's known burn from the turns
# table reaches this. Omit (or 0) to disable — the daemon warns
# loudly at startup, because an engine that can burn money with no
# alarm should be a visible choice.
daily_spend_alarm_usd = 25.0
hooks = ["SessionStart", "UserPromptSubmit", "PreToolUse", "PostToolUse", "Stop", "SessionEnd"]
